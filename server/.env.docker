# Server port
PORT=5000

# Node environment
NODE_ENV=production

# Database connection (Docker service name as host)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stacrm
PGUSER=postgres
PGHOST=postgres
PGPASSWORD=postgres
PGDATABASE=stacrm
PGPORT=5432

# JWT configuration
JWT_
JWT_EXPIRES_IN=1d 